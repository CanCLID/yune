{
	"name": "yune-web",
	"version": "0.0.0",
	"description": "Public browser demo for the Yune input-method engine",
	"type": "module",
	"scripts": {
		"prepare:runtime": "node scripts/prepare-runtime.mjs",
		"start": "npm run prepare:runtime && npm run worker -- --sourcemap && vite --host",
		"build": "npm run prepare:runtime && npm run worker -- --minify && vite build",
		"build:public": "node public-demo/build.mjs",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"worker": "esbuild src/worker.ts --bundle --format=iife --outdir=public",
		"preview": "vite preview --host"
	},
	"dependencies": {
		"@yune-ime/yune-web-runtime": "file:../../packages/yune-web-runtime",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"textarea-caret": "^3.1.0"
	},
	"devDependencies": {
		"@types/emscripten": "^1.39.12",
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"@types/textarea-caret": "^3.0.3",
		"@vitejs/plugin-react-swc": "^3.7.0",
		"autoprefixer": "^10.4.19",
		"esbuild": "^0.21.4",
		"postcss": "^8.4.38",
		"postcss-nesting": "^12.1.5",
		"tailwindcss": "^3.4.3",
		"typescript": "^5.4.5",
		"vite": "^5.2.11"
	},
	"license": "MIT",
	"browserslist": "> 0.5% in HK and fully supports wasm and not dead"
}
