+  const rawText = typeof raw === "string" ? raw : new TextDecoder().decode(raw);
+  const { rows, parseErrors } = parseUserdbRows(rawText);
+  return {
+    ...base,
+    exists: true,
+    bytes: new TextEncoder().encode(rawText).byteLength,
+    updatedAt: userdbUpdatedAt(module.FS, path),
+    rows,
+    rawText,
